# --- 基础配置 ---
# 模型本地绝对路径
QWEN_ASR_MODEL_PATH=/path/to/your/Qwen3-ASR-1.7B

# vLLM 显存占用率 (0.0 - 1.0)
GPU_UTILIZATION=0.8

# 最大上下文长度 (建议 32768, 1.7B 模型设置过大会导致 OOM)
MAX_MODEL_LEN=32768

# 空闲回收时间 (秒, 600 = 10分钟)
# 超过此时间无请求，模型将自动从显存卸载
IDLE_TIMEOUT=600

# 服务运行端口
PORT=8002

# 临时音频文件目录
TEMP_DIR=temp_audio

# 日志目录
LOG_DIR=logs

# --- 超长音频分段配置 ---
# 超过此时长(秒)则启动分段处理 (默认 600s = 10分钟)
CHUNK_THRESHOLD=600

# 每段分段的时长(秒) (默认 300s = 5分钟)
CHUNK_DURATION=300
